{
  "name": "magda-mikolaj/password-lab-devsecops",
  "description": "Laboratory website project with PHP, JavaScript, CI/CD and Security as Code.",
  "type": "project",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/php/"
    }
  },
  "config": {
    "sort-packages": true,
    "vendor-dir": "php-vendor"
  },
  "scripts": {
    "test:php": "phpunit --configuration phpunit.xml",
    "analyse:php": "phpstan analyse"
  }
}